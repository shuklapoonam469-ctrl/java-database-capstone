DELIMITER $$

CREATE PROCEDURE GetTopDoctorOfMonth(IN target_month INT, IN target_year INT)
BEGIN
    SELECT 
        d.id AS doctor_id,
        d.name AS doctor_name,
        d.specialty,
        COUNT(a.id) AS patients_seen
    FROM doctor d
    JOIN appointment a ON d.id = a.doctor_id
    WHERE a.status = 1  -- Only counting completed appointments
      AND MONTH(a.appointment_time) = target_month
      AND YEAR(a.appointment_time) = target_year
    GROUP BY d.id, d.name, d.specialty
    ORDER BY patients_seen DESC
    LIMIT 1;
END$$
