DELIMITER $$

CREATE PROCEDURE GetDailyAppointmentsReport(IN report_date DATE)
BEGIN
    SELECT 
        d.id AS doctor_id,
        d.name AS doctor_name,
        d.specialty,
        COUNT(a.id) AS total_appointments,
        SUM(CASE WHEN a.status = 0 THEN 1 ELSE 0 END) AS scheduled_count,
        SUM(CASE WHEN a.status = 1 THEN 1 ELSE 0 END) AS completed_count,
        SUM(CASE WHEN a.status = 2 THEN 1 ELSE 0 END) AS cancelled_count
    FROM doctor d
    LEFT JOIN appointment a ON d.id = a.doctor_id 
        AND DATE(a.appointment_time) = report_date
    GROUP BY d.id, d.name, d.specialty
    ORDER BY total_appointments DESC;
END$$

DELIMITER ;
